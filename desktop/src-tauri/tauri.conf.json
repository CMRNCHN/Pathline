{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pathline",
  "version": "0.1.0",
  "identifier": "com.pathline.desktop",
  "build": {
    "frontendDist": "../../client/dist",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev --prefix ../client",
    "beforeBuildCommand": "npm run build --prefix ../client"
  },
  "app": {
    "windows": [
      {
        "title": "Pathline",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
