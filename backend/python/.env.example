# Core runtime
PYTHONUNBUFFERED=1

# Twilio (required for live/interactive modes)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567
USER_PHONE_NUMBER=+15557654321

# Deepgram (required for live transcription)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Optional: extra keyword boosts for Deepgram (comma-separated, format: "word:weight")
# Default IVR keywords (account number, credit card, CVV, etc.) are always included.
# DEEPGRAM_KEYWORDS=routing number:2,hold time:1,extension:1

# Stream server auth token (recommended to set explicitly in shared environments)
# If omitted, the app derives one deterministically from TWILIO_ACCOUNT_SID + TWILIO_AUTH_TOKEN.
IVR_STREAM_AUTH_TOKEN=replace_with_long_random_token

# Optional: override GUI stream URL if you are not using auto-ngrok detection
# IVR_STREAM_URL=wss://<your-ngrok-domain>/stream

# SMS server settings (only for `sms-serve`)
# SMS_ALLOWED_SENDERS=+15550001111,+15550002222
# SMS_PUBLIC_BASE_URL=https://<your-public-url>

# ── Audio quality add-ons (optional) ────────────────────────────────────────
# AssemblyAI real-time transcription (paid, ~$0.015/min after free tier)
# Sign up at https://www.assemblyai.com, then uncomment:
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# Twilio Voice Intelligence post-call analytics (paid, ~$0.05/min)
# Create an Intelligence Service in Twilio Console → Voice → Intelligence:
# TWILIO_INTELLIGENCE_SERVICE_SID=GAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dolby.io audio enhancement (free tier: 1,000 min/month, then ~$0.005/min)
# Sign up at https://dolby.io, then uncomment:
# DOLBY_API_KEY=your_dolby_api_key
