{
  "suite_id": "ivr_card_probe",
  "name": "IVR Card Status Probe",
  "description": "Dials IVR, enters menu code 11, enters card number, captures spoken status and hangs up.",
  "target_number": "+15550001234",
  "scenarios": [
    {
      "scenario_id": "card_approved",
      "name": "Card Approved",
      "ivr_status_label": "APPROVED",
      "steps": [
        {
          "step_id": "s1_dial",
          "action": "start_call",
          "timeout_ms": 30000
        },
        {
          "step_id": "s2_greeting",
          "action": "wait_for_prompt",
          "timeout_ms": 20000
        },
        {
          "step_id": "s3_menu",
          "action": "send_dtmf",
          "input_value": "11",
          "timeout_ms": 5000
        },
        {
          "step_id": "s4_card_prompt",
          "action": "wait_for_prompt",
          "timeout_ms": 15000
        },
        {
          "step_id": "s5_card_number",
          "action": "send_dtmf",
          "input_value": "4111111111111111",
          "timeout_ms": 5000
        },
        {
          "step_id": "s6_status_response",
          "action": "wait_for_transcript",
          "expected_text_contains": "approved",
          "timeout_ms": 20000
        },
        {
          "step_id": "s7_hangup",
          "action": "end_call",
          "timeout_ms": 5000
        }
      ]
    },
    {
      "scenario_id": "card_declined",
      "name": "Card Declined",
      "ivr_status_label": "DECLINED",
      "steps": [
        {
          "step_id": "s1_dial",
          "action": "start_call",
          "timeout_ms": 30000
        },
        {
          "step_id": "s2_greeting",
          "action": "wait_for_prompt",
          "timeout_ms": 20000
        },
        {
          "step_id": "s3_menu",
          "action": "send_dtmf",
          "input_value": "11",
          "timeout_ms": 5000
        },
        {
          "step_id": "s4_card_prompt",
          "action": "wait_for_prompt",
          "timeout_ms": 15000
        },
        {
          "step_id": "s5_card_number",
          "action": "send_dtmf",
          "input_value": "4000000000000002",
          "timeout_ms": 5000
        },
        {
          "step_id": "s6_status_response",
          "action": "wait_for_transcript",
          "expected_text_contains": "declined",
          "timeout_ms": 20000
        },
        {
          "step_id": "s7_hangup",
          "action": "end_call",
          "timeout_ms": 5000
        }
      ]
    }
  ]
