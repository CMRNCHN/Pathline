# shellcheck shell=sh
# shellcheck disable=SC2034
# shellcheck shell=sh
# shellcheck disable=SC2034
# ── Core Runtime ─────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
# Set PYTHONPATH=. when running modules directly
PYTHONPATH=.

PATHLINE_HOST="0.0.0.0"
PATHLINE_PORT="8001"
PATHLINE_LOG_LEVEL="debug"

# ── Safety Guards & Allowlist ────────────────────────────────────────────────
# Critical: The system will block any target number not in this list.
# Format: Comma-separated E.164 numbers (+1234567890,+1987654321)
ALLOWLIST_NUMBERS=+15551234567

# Conservative bounds for automated or manual runs
MAX_CALLS_PER_SESSION=1
SESSION_WALL_CLOCK_TIMEOUT_SEC=600

# ── Telephony (Twilio) ───────────────────────────────────────────────────────
# Required for live/interactive modes and bridge operations.
TWILIO_ACCOUNT_SID="AC00000000000000000000000000000000"
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"
TWILIO_PHONE_NUMBER="+16624384811"

# Advanced Telephony Config
TWILIO_CONFERENCE_NUMBER="+16624384811"
TWILIO_CALLER_ID="+16624384811"
ALL_TWILIO_PHONE_NUMBERS="+16624384811,+16174207443,+16079004530,+15715688394,+17743586607,+14454474885,+13636661972,+15086257682,+12027513252,+18282376302"

# Twilio Auto-Managed URLs (Updated by Tunnel Script)
TWILIO_BASE_URL=""
TWILIO_WEBHOOK_URL=""
TWILIO_MEDIA_STREAM_URL=""
TWILIO_STATUS_CALLBACK_URL=""
TWILIO_RECORDING_CALLBACK_URL=""
TWILIO_CONFERENCE_WEBHOOK_URL="https://conference-3374-ndwdbx.twil.io/conference"

# Feature Toggles
ENABLE_TWILIO_MEDIA_STREAMS="true"
ENABLE_TWILIO_RECORDINGS="true"
ENABLE_TWILIO_TRANSCRIPTS="true"
ENABLE_TWILIO_STATUS_CALLBACKS="true"

# Twilio Testing Credentials
TWILIO_TEST_ACCOUNT_SID="AC00000000000000000000000000000000"
TWILIO_TEST_AUTH_TOKEN="your_twilio_test_auth_token"
TWILIO_WEBHOOK_SECRET=""

# Optional: Your personal number for operator bridging/listening in
USER_PHONE_NUMBER=+15557654321

# ── Speech-to-Text (STT) ─────────────────────────────────────────────────────
# Options: mlx-whisper, deepgram, simulated
STT_BACKEND="mlx-whisper"
DEEPGRAM_API_KEY=your_deepgram_api_key

# For mlx-whisper (fully local STT): tiny/base/small/medium/large
WHISPER_MODEL=base

# Optional: extra keyword boosts (comma-separated "word:weight")
DEEPGRAM_KEYWORDS="routing number:2,hold time:1,zipcode:2,credit card number:2,somebody to help:1,secret word:1,security number:2,keypad:1,last four digits:2,recorded:1,touch tone system:1,please hold:1,if you would like:1"

# ── Text-to-Speech (TTS) ─────────────────────────────────────────────────────
# Options: openai, piper, simulated
TTS_BACKEND=openai
OPENAI_API_KEY=your_openai_api_key

# For Piper (local TTS):
# PIPER_BINARY=/usr/local/bin/piper
# PIPER_VOICE=en_US-lessac-medium

# ── Networking & Tunnels ─────────────────────────────────────────────────────
# Options: ngrok, cloudflare, none
TUNNEL_BACKEND=ngrok

# Recommended to set explicitly. If omitted, it is derived from Twilio keys.
IVR_STREAM_AUTH_TOKEN="your_generated_random_token_here"

# Optional: override if not using auto-tunnel detection
# IVR_STREAM_URL=wss://<your-ngrok-domain>/stream

# ── Pathline Security ────────────────────────────────────────────────────────
PATHLINE_JWT_SECRET=""
PATHLINE_SESSION_SECRET=""
PATHLINE_ENCRYPTION_KEY=""
PATHLINE_ADMIN_TOKEN=""

# ── Audio Quality & Analytics (Optional) ─────────────────────────────────────
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key
# DOLBY_API_KEY=your_dolby_api_key
# TWILIO_INTELLIGENCE_SERVICE_SID=GAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Storage ──────────────────────────────────────────────────────────────────
# Root baseline
PATHLINE_BASE_DIR="$HOME/cameroncohen/ideaprojects/pathline"

# Granular directories
PATHLINE_LOG_DIR="$PATHLINE_BASE_DIR/logs"
PATHLINE_EVENT_DIR="$PATHLINE_BASE_DIR/events"
PATHLINE_RECORDING_DIR="$PATHLINE_BASE_DIR/recordings"
PATHLINE_TRANSCRIPT_DIR="$PATHLINE_BASE_DIR/transcripts"
PATHLINE_EXPORT_DIR="$PATHLINE_BASE_DIR/exports"
# SESSION_STORAGE_PATH=/custom/path/to/replays
