# IVRSuite — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Twilio (required to place calls) ────────────────────────────────────────
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000

# ── Deepgram (required for transcription) ───────────────────────────────────
# Get a free key at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ── OpenAI (optional — for AI voice responses) ──────────────────────────────
# Get at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_TTS_VOICE=cedar

# ── Stream auth (optional — auto-generated and saved to ~/.ivr_assessor/.stream_token) ──
# Set this to a fixed value if you want full control over the token,
# e.g. if you're running the stream server and GUI as separate processes.
# IVR_STREAM_AUTH_TOKEN=your-stable-token-here

# ── Twilio callback URL (optional — only needed for call recordings) ─────────
# TWILIO_RECORDING_STATUS_CALLBACK=https://your-ngrok-url/recording-status
