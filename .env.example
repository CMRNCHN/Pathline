# PromptPath v1 — single API service
DATABASE_URL=sqlite+aiosqlite:///./promptpath.db

# Auth
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_TTL_SECONDS=300
SESSION_PEPPER=change-me-in-production-use-openssl-rand-hex-32

# Retention
SESSION_RETENTION_SECONDS=3600

# Client (dev uses Vite proxy — /api → localhost:8000)
VITE_API_URL=/api

# Lab SIP (TLS) — credentials generated on first ./scripts/lab.sh if unset
LAB_SIP_USER=promptpath-lab
LAB_SIP_PASSWORD=
LAB_SIP_TLS_PORT=5061
