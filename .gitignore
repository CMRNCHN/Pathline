# cspell:ignore xcodeproj xcworkspace pycache pytest venv

.DS_Store
.build/
DerivedData/
*.xcodeproj/
*.xcworkspace/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
.codex/
.derived-data/
.venv/
backend/python/.venv/
generated-answer-sheet.txt
.env
.ai/repomix-output.txt
.ai/private-notes.md
.ai/secrets.md

# AI session artifacts
.ai_sessions/
.ai/
.agent.md

# Claude Code local settings and worktrees
.claude/settings.local.json
.claude/worktrees/

# Runtime storage — binary artifacts and large outputs
/storage/*.wav
/storage/*.mp3
/storage/**/*.wav
/storage/**/*.mp3
/storage/recordings/
/storage/replays/
/storage/snapshots/
/storage/benchmarks/
# Allow structural .gitkeep placeholders inside storage/
!/storage/**/.gitkeep

# Audio artifacts — never commit recordings or model files
*.wav
*.mp3
recordings/

# Piper TTS model files (large, downloaded at runtime)
*.onnx
*.onnx.json
voices/

# Whisper / HuggingFace model cache
.cache/

# Secret scanning baseline
.secrets.baseline

# Generated archives
*.zip

# Do not version AIR workspace files
.air/

# Do not version AIR workspace files
.air/
