#!/usr/bin/env bash

python3 -m venv .venv || true
source .venv/bin/activate

pip install -U pip
pip install -e backend/python[dev] || true

mkdir -p storage/replays
mkdir -p storage/reports
mkdir -p storage/benchmarks
mkdir -p storage/recordings
mkdir -p storage/snapshots

mkdir -p .ai/TASKS
mkdir -p .ai/DECISIONS
mkdir -p .ai/SESSION_LOGS

echo "Docker environment ready"