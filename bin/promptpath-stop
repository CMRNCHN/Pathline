#!/usr/bin/env bash
set -euo pipefail

resolve_root() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do
    local dir
    dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd "$(dirname "$src")/.." && pwd
}

ROOT="$(resolve_root)"
exec "$ROOT/scripts/stop.sh" "$@"
