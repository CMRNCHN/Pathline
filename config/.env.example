# IVRSuite — environment variable reference
# Copy to .env at the repo root and fill in your values.
# .env is gitignored — never commit credentials.

# ── Core runtime ──────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1

# ── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Comma-separated list of all owned Twilio numbers
TWILIO_PHONE_NUMBERS=+1XXXXXXXXXX,+1XXXXXXXXXX
# Your personal callback number (receives call status, used in test mode)
USER_PHONE_NUMBER=+1XXXXXXXXXX
# Default target IVR number
TARGET_PHONE_NUMBER=+1XXXXXXXXXX
# Fired when a call recording finishes (needs a public URL)
TWILIO_RECORDING_STATUS_CALLBACK=https://your-ngrok-url.ngrok-free.app/recording-status

# ── Stream server ─────────────────────────────────────────────────────────────
# Shared secret between the GUI server and stream server
IVR_STREAM_AUTH_TOKEN=your-random-secret-here
# Public WebSocket URL that Twilio streams audio to
IVR_STREAM_URL=wss://your-ngrok-url.ngrok-free.app/stream

# ── STT / TTS backends ────────────────────────────────────────────────────────
# STT_BACKEND: faster-whisper (default, local) | deepgram | assemblyai
STT_BACKEND=faster-whisper
# TTS_BACKEND: piper (default, local) | openai
TTS_BACKEND=piper

# ── Faster-Whisper (local STT) ────────────────────────────────────────────────
# WHISPER_MODEL: tiny.en | base.en | small.en | medium.en | large-v3
WHISPER_MODEL=base.en
WHISPER_DEVICE=cpu
# Minimum transcript confidence to accept (0.0–1.0)
WHISPER_CONFIDENCE_MIN=0.6

# ── Piper (local TTS) ─────────────────────────────────────────────────────────
# Path to the piper binary
PIPER_BINARY=/usr/local/bin/piper
# Path to a .onnx voice model
PIPER_VOICE=/path/to/voice.onnx
PIPER_SAMPLE_RATE=22050

# ── Deepgram (cloud STT) ──────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key
# Optional: comma-separated keyword boosts
# DEEPGRAM_KEYWORDS=visa,mastercard,account

# ── OpenAI (cloud TTS) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxx
OPENAI_TTS_VOICE=alloy

# ── AssemblyAI (cloud STT alternative) ───────────────────────────────────────
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# ── Twilio Voice Intelligence (optional, paid ~$0.05/min) ────────────────────
# TWILIO_INTELLIGENCE_SERVICE_SID=GAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Dolby.io audio enhancement (optional, free tier 1,000 min/month) ─────────
# DOLBY_API_KEY=your_dolby_api_key

# ── SMS server (only for `sms-serve` subcommand) ─────────────────────────────
SMS_ALLOWED_SENDERS=+1XXXXXXXXXX
SMS_PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── Reports & logging ─────────────────────────────────────────────────────────
# Override default storage location (~/.ivr_assessor/reports)
# IVR_REPORTS_DIR=~/.ivr_assessor/reports
LOG_LEVEL=INFO
# LOG_FORMAT=json
