{
  "id": "template",
  "version": 2,
  "setup": {
    "name": "Claim status check",
    "description": "Submit account number, capture claim status from the IVR.",
    "target": "+18005551234",
    "timeoutMs": 30000,
    "speechPreferences": { "autoListen": false },
    "runtimeVariables": ["account_number"]
  },
  "ivrRules": [
    {
      "id": "rule-1",
      "label": "submit_account_number",
      "trigger": "account number",
      "response": "{{account_number}}",
      "rule": "Inject DTMF after detect",
      "output": ""
    },
    {
      "id": "rule-2",
      "label": "capture_claim_status",
      "trigger": "claim status",
      "response": "",
      "rule": "Capture value after detect",
      "output": "claim_status"
    },
    {
      "id": "rule-3",
      "label": "end_call",
      "trigger": "",
      "response": "",
      "rule": "End call",
      "output": ""
    }
  ],
  "conversationFlow": []
}
