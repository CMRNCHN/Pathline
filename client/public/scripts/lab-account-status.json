{
  "id": "lab-account-status",
  "version": 2,
  "setup": {
    "name": "Lab account status (Asterisk 1000)",
    "description": "Maps to the Pathline lab IVR. Desktop app (Tauri + rsiprtp SIP bridge) owns the call: it dials extension 1000 and composes the full SIP URI from LAB_SIP_*/PATHLINE_SIP_* env (host/creds from lab/asterisk/generated/credentials.env). Softphone + manual paste is a legacy browser fallback only. See docs/lab-run.md.",
    "target": "1000",
    "timeoutMs": 30000,
    "speechPreferences": { "autoListen": true },
    "runtimeVariables": ["account_pin", "ssn_last4"]
  },
  "ivrRules": [
    {
      "id": "rule-main-menu",
      "label": "main_menu",
      "trigger": "account|press 1 for account|option 1",
      "response": "1",
      "rule": "Inject DTMF after detect",
      "output": ""
    },
    {
      "id": "rule-touch-tone",
      "label": "touch_tone",
      "trigger": "touch tone|touchtone|press 9|keypad",
      "response": "9",
      "rule": "Inject DTMF after detect",
      "output": ""
    },
    {
      "id": "rule-pin",
      "label": "pin_entry",
      "trigger": "pin|personal identification|enter your pin",
      "response": "{{account_pin}}#",
      "rule": "Inject DTMF after detect",
      "output": ""
    },
    {
      "id": "rule-ssn",
      "label": "ssn_entry",
      "trigger": "last four|social security|last four of your social",
      "response": "{{ssn_last4}}#",
      "rule": "Inject DTMF after detect",
      "output": ""
    },
    {
      "id": "rule-status-menu",
      "label": "status_menu",
      "trigger": "balance|press 1 for balance|hear your balance",
      "response": "1",
      "rule": "Inject DTMF after detect",
      "output": ""
    },
    {
      "id": "rule-capture",
      "label": "read_status",
      "trigger": "your balance|your dollars|1234|current balance",
      "response": "",
      "rule": "Capture value after detect",
      "output": "account_balance"
    },
    {
      "id": "rule-end",
      "label": "end_call",
      "trigger": "",
      "response": "",
      "rule": "End call",
      "output": ""
    }
  ],
  "conversationFlow": []
}
