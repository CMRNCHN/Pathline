{
  "id": "utility-account",
  "name": "Utility Account Status",
  "description": "Check utility account — current, past due, or suspended.",
  "target": "+18005551234",
  "timeoutMs": 45000,
  "tags": ["Utility"],
  "setupComplete": true,
  "secrets": [
    {
      "id": "s1",
      "name": "account_number",
      "description": "Account number on your bill",
      "example": "123456789",
      "required": true
    },
    {
      "id": "s2",
      "name": "account_pin",
      "description": "PIN or passcode",
      "example": "••••",
      "required": true
    },
    {
      "id": "s3",
      "name": "zip_code",
      "description": "Billing zip code",
      "example": "20009",
      "required": true
    }
  ],
  "results": [
    { "id": "r1", "key": "account_status", "description": "Account standing" }
  ],
  "conversation": [
    { "id": "c1", "listenFor": "welcome|main menu", "action": "send_keys", "keys": "1" },
    { "id": "c2", "listenFor": "account number|enter your account", "action": "send_keys", "keys": "{account_number}#" },
    { "id": "c3", "listenFor": "personal identification|pin", "action": "send_keys", "keys": "{account_pin}#" },
    { "id": "c4", "listenFor": "billing zip|zip code", "action": "send_keys", "keys": "{zip_code}#" },
    { "id": "c5", "listenFor": "account is current|no balance due|paid in full", "action": "save_value", "resultKey": "account_status", "value": "current" },
    { "id": "c6", "listenFor": "", "action": "hang_up" },
    { "id": "c7", "listenFor": "past due|amount due|payment required", "action": "save_value", "resultKey": "account_status", "value": "past_due" },
    { "id": "c8", "listenFor": "", "action": "hang_up" },
    { "id": "c9", "listenFor": "disconnected|service suspended", "action": "save_value", "resultKey": "account_status", "value": "suspended" },
    { "id": "c10", "listenFor": "", "action": "hang_up" }
  ]
}
